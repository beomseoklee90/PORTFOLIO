{
  "name": "magazine-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "bundle": "inline-assets out/index.html out/single-index.html",
    "build": "next build",
    "inline": "node inline.js && rm -f out/*.txt",
    "deploy": "npm run build && gh-pages -d out -b deploy",
    "deploy2": "gh-pages -d out -b deploy2"
  },
  "dependencies": {
    "framer-motion": "^12.36.0",
    "next": "16.1.6",
    "page-flip": "^2.0.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-pageflip": "^2.0.3",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "gh-pages": "^6.3.0",
    "inline-source-cli": "^2.0.0",
    "posthtml": "^0.16.7",
    "posthtml-inline-assets": "^3.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
